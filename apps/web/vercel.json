{
  "alias": ["threely-app.vercel.app"],
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @threely/web build",
  "crons": [
    {
      "path": "/api/cron/cleanup-anon",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/renewal-reminders",
      "schedule": "0 14 * * *"
    }
  ]
}
