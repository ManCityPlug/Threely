// Threely — Prisma Schema
// Database: PostgreSQL via Supabase
// Run `pnpm db:push` to sync schema, `pnpm db:generate` to regenerate client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // For Supabase: use the connection pooler URL for DATABASE_URL
  // and the direct connection URL for DIRECT_URL (used by migrations)
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
// Mirrors Supabase auth.users. Created automatically via a Supabase DB trigger
// or manually after the user registers.
model User {
  id                 String       @id @default(uuid()) // matches Supabase auth.users.id
  email              String       @unique
  createdAt          DateTime     @default(now()) @map("created_at")
  stripeCustomerId   String?      @map("stripe_customer_id")
  subscriptionId     String?      @map("subscription_id")
  subscriptionStatus String?      @map("subscription_status")
  trialClaimedAt     DateTime?    @map("trial_claimed_at")
  trialDeviceId      String?      @map("trial_device_id")
  trialEndsAt        DateTime?    @map("trial_ends_at")
  rcSubscriptionActive Boolean   @default(false) @map("rc_subscription_active")
  pauseEndsAt        DateTime?    @map("pause_ends_at")
  lastSaveOfferAt    DateTime?    @map("last_save_offer_at")
  goals              Goal[]
  dailyTasks         DailyTask[]
  dailyFocus         DailyFocus[]
  weeklySummaries    WeeklySummary[]
  profile            UserProfile?
  offers             Offer[]
  launches           Launch[]

  @@map("users")
}

// ─── Offer ───────────────────────────────────────────────────────────────────
// Admin-granted special offers (discounts, free months, pauses).
// One active offer per user at a time.
model Offer {
  id             String    @id @default(uuid())
  userId         String
  type           String    // 'discount_percent' | 'discount_amount' | 'free_month' | 'pause'
  value          Float     // 50 (for 50%) or 30 (for days) or 12.99 (for $)
  duration       String?   // 'once' | 'repeating' (for discounts)
  durationMonths Int?      // for repeating discounts
  description    String    // human-readable: "50% off next month"
  mode           String    // 'manual' | 'auto'
  status         String    // 'pending' | 'claimed' | 'expired' | 'auto_applied' | 'revoked'
  expiresAt      DateTime
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("offers")
  @@index([userId])
  @@index([status])
}

// ─── UserProfile ─────────────────────────────────────────────────────────────
// 1:1 with User. Stores coaching preferences set during onboarding.
// intensityLevel: 1=steady/habit, 2=committed/progress, 3=all_in
model UserProfile {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  dailyTimeMinutes Int      @default(60) @map("daily_time_minutes")
  intensityLevel   Int      @default(2) @map("intensity_level")
  theme            String   @default("light") @map("theme")
  coachingContext  Json?    @map("coaching_context")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── Goal ────────────────────────────────────────────────────────────────────
model Goal {
  id                String      @id @default(cuid())
  userId            String      @map("user_id")
  title             String
  description       String?
  rawInput          String      @default("") @map("raw_input")
  structuredSummary String?     @map("structured_summary")
  category          String?
  deadline          DateTime?
  dailyTimeMinutes  Int?        @map("daily_time_minutes")
  intensityLevel    Int?        @map("intensity_level")
  roadmap           String?     @db.Text
  isActive          Boolean     @default(true) @map("is_active")
  isPaused          Boolean     @default(false) @map("is_paused")
  workDays          Int[]       @default([1, 2, 3, 4, 5, 6, 7]) @map("work_days")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyTasks        DailyTask[]

  @@index([userId])
  @@map("goals")
}

// ─── DailyTask ───────────────────────────────────────────────────────────────
// One record per (goal, date). The `tasks` JSON field holds an array of
// TaskItem objects generated by Claude.
//
// TaskItem shape (stored as JSON):
// {
//   id: string, task: string, description: string,
//   estimated_minutes: number, goal_id: string, why: string,
//   isCompleted: boolean, isSkipped?: boolean
// }
model DailyTask {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  goalId      String       @map("goal_id")
  date        DateTime     @db.Date          // e.g. 2025-08-01 (no time component)
  tasks       Json                           // TaskItem[]
  isCompleted Boolean      @default(false) @map("is_completed")
  completedAt DateTime?    @map("completed_at")
  generatedAt DateTime     @default(now()) @map("generated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  review      DailyReview?

  @@unique([goalId, date])
  @@index([userId, date])
  @@map("daily_tasks")
}

// ─── DailyFocus ──────────────────────────────────────────────────────────────
// Tracks which goal the user focused on each day. Used by heatmap to count
// only the focused tasks, not all goals.
model DailyFocus {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  date            DateTime @db.Date
  focusGoalId     String   @map("focus_goal_id")   // goal cuid OR "shuffle"
  shuffleTaskIds  Json?    @map("shuffle_task_ids") // string[] of TaskItem IDs when shuffle
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_focus")
}

// ─── DailyReview ─────────────────────────────────────────────────────────────
// End-of-day review submitted after completing tasks.
// difficultyRating: too_easy | just_right | challenging | overwhelming
// completionStatus: all_done | most_of_them | didnt_get_to_them
model DailyReview {
  id               String    @id @default(cuid())
  dailyTaskId      String    @unique @map("daily_task_id")
  userId           String    @map("user_id")
  difficultyRating String    @map("difficulty_rating")
  completionStatus String    @map("completion_status")
  userNote         String?   @map("user_note")
  insight          String?
  createdAt        DateTime  @default(now()) @map("created_at")

  dailyTask        DailyTask @relation(fields: [dailyTaskId], references: [id], onDelete: Cascade)

  @@map("daily_reviews")
}

// ─── WeeklySummary ──────────────────────────────────────────────────────────
// Frozen weekly snapshot generated on first open after the week ends.
// Stats JSON is self-contained so deleted goals don't affect historical data.
model WeeklySummary {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  weekStart     DateTime  @db.Date          // Monday date (e.g. 2026-02-23)
  stats         Json                        // Frozen snapshot of all metrics
  insight       String?                     // AI coaching text
  timezone      String                      // e.g. "America/New_York"
  firstOpenedAt DateTime? @map("first_opened_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("weekly_summaries")
}

// ─── Notification ──────────────────────────────────────────────────────────
// Admin-created notifications. If targetUserIds is empty, goes to all users.
// If populated, only those users see it.
model Notification {
  id            String   @id @default(cuid())
  heading       String
  subheading    String
  linkUrl       String?  @map("link_url")
  targetUserIds String[] @default([]) @map("target_user_ids")
  createdAt     DateTime @default(now()) @map("created_at")

  dismissals NotificationDismissal[]

  @@map("notifications")
}

// ─── NotificationDismissal ─────────────────────────────────────────────────
// Tracks which users have read/dismissed which notifications.
model NotificationDismissal {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  notificationId String       @map("notification_id")
  dismissedAt    DateTime     @default(now()) @map("dismissed_at")

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@map("notification_dismissals")
}

// ─── TrialCardFingerprint ─────────────────────────────────────────────────
// Survives account deletion. Prevents the same credit card from claiming
// multiple free trials across different accounts.
model TrialCardFingerprint {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  email       String
  claimedAt   DateTime @default(now()) @map("claimed_at")

  @@map("trial_card_fingerprints")
}

// ─── SystemConfig ──────────────────────────────────────────────────────────
// Key-value store for admin-configurable system settings (e.g. minAppVersion).
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

// ─── CancellationFeedback ────────────────────────────────────────────────────
// Records why users cancel — used to improve product retention.
model CancellationFeedback {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  reason    String
  feedback  String?
  plan      String   // yearly or monthly
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("cancellation_feedback")
}

// ─── AICallLog ───────────────────────────────────────────────────────────────
// Silent log of every Claude API call for future LLM fine-tuning.
model AICallLog {
  id              String   @id @default(cuid())
  userId          String
  functionName    String   // "parseGoal" | "generateTasks" | "generateRoadmap" | "goalChat"
  modelUsed       String   // "claude-opus-4-6" | "claude-sonnet-4-6" | "claude-haiku-4-5-20251001"
  inputData       String   @db.Text  // JSON string of the input parameters
  outputData      String   @db.Text  // JSON string of Claude's response
  inputTokens     Int?
  outputTokens    Int?
  responseTimeMs  Int?     // how long the call took
  goalId          String?  // nullable, links to which goal this was for
  taskFeedback    String?  // nullable, updated later: "completed" | "skipped" | "rescheduled" | "edited"
  feedbackAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([functionName])
  @@index([goalId])
  @@index([createdAt])
}

// ─── Launch (DFY ecommerce launch) ───────────────────────────────────────────
// One per user. Represents the end-to-end DFY ecom build.
// Phases are templated in code (1=Foundation, 2=Branding, 3=Store, 4=First Ads,
// 5=Scale, 6=Growth). currentPhase advances as assets/work complete.
model Launch {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  businessName   String         @map("business_name")
  niche          String
  currentPhase   Int            @default(1) @map("current_phase")
  status         String         @default("active") // "active" | "paused" | "completed"
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets         LaunchAsset[]
  events         LaunchEvent[]

  @@map("launches")
  @@index([userId])
  @@index([status])
}

// ─── LaunchAsset ─────────────────────────────────────────────────────────────
// Assets delivered (or in-progress) for a launch. Generated by AI or uploaded
// manually via admin. `payload` is a JSON blob whose shape varies by kind:
//   logo         → { pngUrl, svg?, palette? }
//   store        → { url, platform }
//   product_page → { url, productTitle? }
//   ad           → { videoUrl?, imageUrl?, hook?, copy? }
//   ugc          → { videoUrl, hook? }
//   email        → { subject, previewUrl? }
model LaunchAsset {
  id           String   @id @default(uuid())
  launchId     String   @map("launch_id")
  kind         String   // "logo" | "store" | "product_page" | "ad" | "ugc" | "email"
  title        String
  status       String   @default("in_progress") // "in_progress" | "in_review" | "ready"
  payload      Json?
  aiGenerated  Boolean  @default(true) @map("ai_generated")
  createdAt    DateTime @default(now()) @map("created_at")
  deliveredAt  DateTime? @map("delivered_at")

  launch       Launch   @relation(fields: [launchId], references: [id], onDelete: Cascade)

  @@map("launch_assets")
  @@index([launchId])
  @@index([status])
  @@index([kind])
}

// ─── LaunchEvent ─────────────────────────────────────────────────────────────
// Activity log for a launch. Feeds the "latest move" line on /launch and the
// event timeline on the admin detail view.
model LaunchEvent {
  id         String   @id @default(uuid())
  launchId   String   @map("launch_id")
  kind       String   // "phase_change" | "asset_ready" | "note" | "upcoming"
  title      String
  detail     String?
  eta        String?  // freeform: "Thursday", "next week" — used for upcoming
  createdAt  DateTime @default(now()) @map("created_at")

  launch     Launch   @relation(fields: [launchId], references: [id], onDelete: Cascade)

  @@map("launch_events")
  @@index([launchId, createdAt(sort: Desc)])
  @@index([kind])
}
